{
  "name": "BhekThink Sovereign",
  "short_name": "BhekThink",
  "description": "Sovereign AI assistant with multimodal capabilities – chat, image generation, file analysis, and multi‑agent orchestration.",
  "id": "/BhekThink/",
  "start_url": "/BhekThink/",
  "scope": "/BhekThink/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "any",
  "theme_color": "#000000",
  "background_color": "#000000",
  "dir": "ltr",
  "lang": "en",
  "categories": ["productivity", "utilities"],
  "iarc_rating_id": "",
  "related_applications": [],
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "New Chat",
      "short_name": "New",
      "description": "Start a new conversation",
      "url": "/BhekThink/?new",
      "icons": [
        {
          "src": "icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Upload File",
      "short_name": "Upload",
      "description": "Upload a document",
      "url": "/BhekThink/?upload",
      "icons": [
        {
          "src": "icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshot-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop view of BhekThink"
    },
    {
      "src": "screenshot-mobile.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile view of BhekThink"
    }
  ],
  "file_handlers": [
    {
      "action": "/BhekThink/",
      "accept": {
        "text/plain": [".txt"],
        "application/pdf": [".pdf"],
        "image/*": [".jpg", ".jpeg", ".png", ".gif"]
      }
    }
  ],
  "share_target": {
    "action": "/BhekThink/",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+bhekthink",
      "url": "/BhekThink/?command=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "window_controls_overlay": true,
  "scope_extensions": [
    {
      "origin": "https://*.puter.com"
    }
  ]
}
